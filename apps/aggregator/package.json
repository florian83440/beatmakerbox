{
  "name": "@beatmakerbox/aggregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--experimental-sqlite tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --experimental-sqlite --enable-source-maps dist/server.js",
    "aggregate": "cross-env NODE_OPTIONS=--experimental-sqlite tsx src/jobs/aggregate.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@beatmakerbox/dsp": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.2.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2"
  }
}
