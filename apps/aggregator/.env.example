# Beatmakerbox aggregator — environment variables.

# HTTP server bind
PORT=3001
HOST=0.0.0.0

# CORS — comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,https://beatmakerbox.example.com

# SQLite DB path. When running in Docker, mount a volume here.
DB_PATH=./data/aggregator.db

# Reddit subreddits to poll (comma-separated)
REDDIT_SUBS=Drumkits,freedrums,WeAreTheMusicMakers

# User-Agent sent to Reddit (mandatory by their TOS)
REDDIT_USER_AGENT=beatmakerbox-aggregator/0.1 (+https://beatmakerbox.example.com)

# Cron schedule for the daily aggregation (node-cron syntax — UTC).
# Default: every day at 03:17 UTC.
AGGREGATE_CRON=17 3 * * *

# Run aggregation once at boot (true|false). Useful in dev / first deploy.
AGGREGATE_ON_BOOT=true
