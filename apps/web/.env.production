# Production-only env, picked up by Vite at `pnpm build` time.
# (Vite inlines import.meta.env.VITE_* at build, NOT at runtime.)

# Public Packs API URL. The aggregator lives on its own subdomain, so the
# frontend talks to it cross-origin. The aggregator's CORS_ORIGINS must
# include https://beatmakerbox.com (it does — see apps/aggregator/.env).
VITE_PACKS_API_URL=https://api.beatmakerbox.com/api
